{
  "manifest_version": "0.1.0",
  "config_schema": {
    "type": "object",
    "properties": {
      "officeqa_agent_openai_api_key": {
        "type": "string",
        "secret": true
      },
      "officeqa_agent_openai_model": {
        "type": "string"
      },
      "officeqa_agent_reasoning_effort": {
        "type": "string"
      }
    },
    "required": [
      "officeqa_agent_openai_api_key"
    ],
    "additionalProperties": false
  },
  "components": {
    "gateway": {
      "manifest": "https://raw.githubusercontent.com/RDI-Foundation/agentbeats-gateway/refs/tags/v0.3/amber-manifest.json5",
      "config": {
        "assessment_config": {
          "dataset_url": "https://raw.githubusercontent.com/databricks/officeqa/6aa8c32/officeqa.csv",
          "num_questions": 246,
          "difficulty": "all",
          "tolerance": 0,
          "max_concurrent": 10,
          "run_id": 5
        },
        "participant_roles": {
          "green": "green",
          "purple1": "officeqa_agent"
        },
        "callback_urls": {}
      }
    },
    "green": {
      "manifest": "https://raw.githubusercontent.com/RDI-Foundation/officeqa-agentbeats/refs/heads/main/amber/amber-manifest-green.json5",
      "config": {}
    },
    "officeqa_agent": {
      "manifest": "https://raw.githubusercontent.com/ab-shetty/mids-officeqa-alpha/main/amber-manifest.json5",
      "config": {
        "openai_api_key": "${config.officeqa_agent_openai_api_key}",
        "openai_model": "${config.officeqa_agent_openai_model}",
        "reasoning_effort": "${config.officeqa_agent_reasoning_effort}"
      }
    }
  },
  "bindings": [
    {
      "to": "#gateway.green",
      "from": "#green.a2a"
    },
    {
      "to": "#gateway.purple1",
      "from": "#officeqa_agent.a2a"
    },
    {
      "to": "#green.proxy",
      "from": "#gateway.proxy",
      "weak": true
    }
  ],
  "exports": {
    "results": "#gateway.results"
  },
  "metadata": {
    "agentbeats_ids": {
      "green": "019ca14f-cbd5-7a71-9b2b-d43db92a09e1",
      "officeqa_agent": "019d8518-b79a-7e81-9e05-86cfd3ceb168"
    }
  }
}