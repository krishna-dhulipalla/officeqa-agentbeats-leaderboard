{
  "manifest_version": "0.1.0",
  "config_schema": {
    "type": "object",
    "properties": {
      "officeqa_agent_gemini_api_key": {
        "type": "string",
        "secret": true
      },
      "officeqa_agent_llm": {
        "type": "string"
      },
      "officeqa_agent_openai_api_key": {
        "type": "string",
        "secret": true
      }
    },
    "required": [
      "officeqa_agent_llm"
    ],
    "additionalProperties": false
  },
  "components": {
    "gateway": {
      "manifest": "https://raw.githubusercontent.com/RDI-Foundation/agentbeats-gateway/refs/tags/v0.3/amber-manifest.json5",
      "config": {
        "assessment_config": {
          "dataset_url": "https://raw.githubusercontent.com/databricks/officeqa/6aa8c32/officeqa.csv",
          "num_questions": 246,
          "difficulty": "all",
          "tolerance": 0,
          "run_id": 3
        },
        "participant_roles": {
          "green": "green",
          "purple1": "officeqa_agent"
        },
        "callback_urls": {}
      }
    },
    "green": {
      "manifest": "https://raw.githubusercontent.com/RDI-Foundation/officeqa-agentbeats/refs/heads/main/amber/amber-manifest-green.json5",
      "config": {}
    },
    "officeqa_agent": {
      "manifest": "https://raw.githubusercontent.com/Andrew7234/officeqa-baseline-purple/refs/heads/main/amber-manifest.json5",
      "config": {
        "gemini_api_key": "${config.officeqa_agent_gemini_api_key}",
        "llm": "${config.officeqa_agent_llm}",
        "openai_api_key": "${config.officeqa_agent_openai_api_key}"
      }
    }
  },
  "bindings": [
    {
      "to": "#gateway.green",
      "from": "#green.a2a"
    },
    {
      "to": "#gateway.purple1",
      "from": "#officeqa_agent.a2a"
    },
    {
      "to": "#green.proxy",
      "from": "#gateway.proxy",
      "weak": true
    }
  ],
  "exports": {
    "results": "#gateway.results"
  },
  "metadata": {
    "agentbeats_ids": {
      "green": "019ca14f-cbd5-7a71-9b2b-d43db92a09e1",
      "officeqa_agent": "019d7898-61c9-7c20-99fa-6aa148f52961"
    }
  }
}