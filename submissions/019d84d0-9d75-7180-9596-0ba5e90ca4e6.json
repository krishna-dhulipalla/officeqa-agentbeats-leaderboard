{
  "manifest_version": "0.1.0",
  "config_schema": {
    "type": "object",
    "properties": {
      "officeqa_agent_google_api_key": {
        "type": "string",
        "secret": true,
        "description": "Gemini AI Studio API Key"
      },
      "officeqa_agent_google_api_key_2": {
        "type": "string",
        "secret": true,
        "description": "Backup Gemini API Key 2"
      },
      "officeqa_agent_google_api_key_3": {
        "type": "string",
        "secret": true,
        "description": "Backup Gemini API Key 3"
      },
      "officeqa_agent_langsmith_api_key": {
        "type": "string",
        "secret": true,
        "description": "LangSmith tracing API key"
      }
    },
    "required": [
      "officeqa_agent_google_api_key"
    ],
    "additionalProperties": false
  },
  "components": {
    "gateway": {
      "manifest": "https://raw.githubusercontent.com/RDI-Foundation/agentbeats-gateway/refs/tags/v0.3/amber-manifest.json5",
      "config": {
        "assessment_config": {
          "dataset_url": "https://raw.githubusercontent.com/databricks/officeqa/6aa8c32/officeqa.csv",
          "num_questions": 6,
          "difficulty": "all",
          "tolerance": 0,
          "max_concurrent": 3,
          "run_id": 3
        },
        "participant_roles": {
          "green": "green",
          "purple1": "officeqa_agent"
        },
        "callback_urls": {}
      }
    },
    "green": {
      "manifest": "https://raw.githubusercontent.com/RDI-Foundation/officeqa-agentbeats/refs/heads/main/amber/amber-manifest-green.json5",
      "config": {}
    },
    "officeqa_agent": {
      "manifest": "https://raw.githubusercontent.com/MDadopoulos/VeritasX/main/workspace/amber-manifest.json5",
      "config": {
        "google_api_key": "${config.officeqa_agent_google_api_key}",
        "google_api_key_2": "${config.officeqa_agent_google_api_key_2}",
        "google_api_key_3": "${config.officeqa_agent_google_api_key_3}",
        "langsmith_api_key": "${config.officeqa_agent_langsmith_api_key}"
      }
    }
  },
  "bindings": [
    {
      "to": "#gateway.green",
      "from": "#green.a2a"
    },
    {
      "to": "#gateway.purple1",
      "from": "#officeqa_agent.a2a"
    },
    {
      "to": "#green.proxy",
      "from": "#gateway.proxy",
      "weak": true
    }
  ],
  "exports": {
    "results": "#gateway.results"
  },
  "metadata": {
    "agentbeats_ids": {
      "green": "019ca14f-cbd5-7a71-9b2b-d43db92a09e1",
      "officeqa_agent": "019d849a-db00-79a2-bd01-f33a0da795b4"
    }
  }
}