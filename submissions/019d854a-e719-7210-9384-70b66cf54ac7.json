{
  "manifest_version": "0.1.0",
  "config_schema": {
    "type": "object",
    "properties": {
      "officeqa_agent_aegis_api_key": {
        "type": "string",
        "secret": true
      },
      "officeqa_agent_aegis_url": {
        "type": "string"
      },
      "officeqa_agent_gemma_api_key": {
        "type": "string",
        "secret": true
      },
      "officeqa_agent_gemma_model": {
        "type": "string"
      },
      "officeqa_agent_gemma_url": {
        "type": "string"
      }
    },
    "required": [],
    "additionalProperties": false
  },
  "components": {
    "gateway": {
      "manifest": "https://raw.githubusercontent.com/RDI-Foundation/agentbeats-gateway/refs/tags/v0.3/amber-manifest.json5",
      "config": {
        "assessment_config": {
          "dataset_url": "https://raw.githubusercontent.com/databricks/officeqa/6aa8c32/officeqa.csv",
          "num_questions": 20,
          "difficulty": "all",
          "tolerance": 0,
          "max_concurrent": 10,
          "run_id": 3
        },
        "participant_roles": {
          "green": "green",
          "purple1": "officeqa_agent"
        },
        "callback_urls": {}
      }
    },
    "green": {
      "manifest": "https://raw.githubusercontent.com/RDI-Foundation/officeqa-agentbeats/refs/heads/main/amber/amber-manifest-green.json5",
      "config": {}
    },
    "officeqa_agent": {
      "manifest": "https://raw.githubusercontent.com/aiking931931/aegis-purple/main/amber-manifest.json5",
      "config": {
        "aegis_api_key": "${config.officeqa_agent_aegis_api_key}",
        "aegis_url": "${config.officeqa_agent_aegis_url}",
        "gemma_api_key": "${config.officeqa_agent_gemma_api_key}",
        "gemma_model": "${config.officeqa_agent_gemma_model}",
        "gemma_url": "${config.officeqa_agent_gemma_url}"
      }
    }
  },
  "bindings": [
    {
      "to": "#gateway.green",
      "from": "#green.a2a"
    },
    {
      "to": "#gateway.purple1",
      "from": "#officeqa_agent.a2a"
    },
    {
      "to": "#green.proxy",
      "from": "#gateway.proxy",
      "weak": true
    },
    {
      "to": "#officeqa_agent.proxy",
      "from": "#gateway.proxy",
      "weak": true
    }
  ],
  "exports": {
    "results": "#gateway.results"
  },
  "metadata": {
    "agentbeats_ids": {
      "green": "019ca14f-cbd5-7a71-9b2b-d43db92a09e1",
      "officeqa_agent": "019d82b5-eb19-7871-85ec-d2d7d3a8643b"
    }
  }
}